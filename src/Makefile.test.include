# Test executable
if ENABLE_TESTS

test_maryjanecoin_SOURCES = \
  test/test_bitcoin.cpp \
  test/block_signature_tests.cpp \
  test/transaction_record_tests.cpp \
  test/test_privacy.cpp \
  test/serialize_canonical_tests.cpp \
  test/test_devfund.cpp \
  test/coinjoin_tests.cpp

# test_mweb references mw:: symbols (PedersenContext/CMMR/CMWState) that only exist
# in --enable-mweb builds; compile it only when MWEB is enabled, else the combined
# test binary fails to link (undefined references) in the default --enable-mweb=no build.
if ENABLE_MWEB
test_maryjanecoin_SOURCES += test/test_mweb.cpp
endif

test_maryjanecoin_CPPFLAGS = $(AM_CPPFLAGS) $(BITCOIN_INCLUDES) -I$(srcdir)/test -DENABLE_MWEB
test_maryjanecoin_CXXFLAGS = $(AM_CXXFLAGS) $(PIE_FLAGS)
test_maryjanecoin_LDFLAGS = $(RELDFLAGS) $(AM_LDFLAGS) $(LIBTOOL_APP_LDFLAGS) $(PTHREAD_FLAGS)

test_maryjanecoin_LDADD = \
  $(LIBBITCOIN_SERVER) \
  $(maryjanecoin_bin_ldadd) \
  $(top_srcdir)/depends/x86_64-pc-linux-gnu/lib/libboost_unit_test_framework-mt-x64.a

if TARGET_WINDOWS
test_maryjanecoin_SOURCES += test/test_bitcoin-res.rc
endif

if TARGET_LINUX
test_maryjanecoin_LDADD += -lrt
endif

check_PROGRAMS += test_maryjanecoin
TESTS += test_maryjanecoin

endif # ENABLE_TESTS

